DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/accuhear?schema=public"

# Documents / Scanning
# DOCUMENT_STORAGE_PROVIDER=local
# DOCUMENT_STORAGE_LOCAL_ROOT=./var/uploads/documents
# SCANNER_INGEST_API_KEY=
#
# Local scanner mode (button triggers `scanimage` directly on app server)
# SCANNER_LOCAL_ENABLED=false
# SCANNER_SANE_DEVICE=
# SCANNER_SANE_SOURCE=
# SCANNER_SANE_MODE=Color
# SCANNER_SANE_RESOLUTION=300

# Browser->Windows local bridge (recommended for remote Windows front desk PCs)
# NEXT_PUBLIC_SCANNER_BRIDGE_URL=http://127.0.0.1:8765
# NEXT_PUBLIC_SCANNER_BRIDGE_KEY=

# RingCentral API Configuration (JWT Authentication)
# RC_CLIENT_ID=
# RC_CLIENT_SECRET=
# RC_SERVER_URL=https://platform.ringcentral.com
# RC_JWT_TOKEN=
#
# SMS
# RC_LIVE_SMS=false
# RC_FROM_NUMBER=+15551234567
#
# Webhooks
# RC_WEBHOOK_SECRET=
#
# Jobs (Phase 1.5+)
# JOB_SECRET=

# Click2Mail
# Use staging first: https://stage-rest.click2mail.com/molpro
# Production: https://rest.click2mail.com/molpro
# CLICK2MAIL_ENABLED=false
# CLICK2MAIL_USERNAME=
# CLICK2MAIL_PASSWORD=
# CLICK2MAIL_BASE_URL=https://stage-rest.click2mail.com/molpro
# CLICK2MAIL_DEFAULT_JOB_TEMPLATE_ID=
# CLICK2MAIL_DEFAULT_SENDER_NAME=
# CLICK2MAIL_DOCUMENT_CLASS=Letter 8.5 x 11
# CLICK2MAIL_LAYOUT=Address on Separate Page
# CLICK2MAIL_PRODUCTION_TIME=Next Day
# CLICK2MAIL_ENVELOPE=#10 Double Window
# CLICK2MAIL_COLOR=Black and White
# CLICK2MAIL_PAPER_TYPE=White 24#
# CLICK2MAIL_PRINT_OPTION=Printing One side
# CLICK2MAIL_BILLING_TYPE=User Credit
